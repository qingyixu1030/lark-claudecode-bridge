# 飞书应用凭证（在 https://open.feishu.cn/app 创建应用后获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude 默认配置
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_CWD=~
SESSIONS_DIR=~/.lark-claude

# Shared project memory root for Agent Hub
PROJECTS_ROOT=~/projects
AGENT_HUB_ROOT=~/projects/_agent-hub

# 工具权限模式：bypassPermissions（跳过所有确认，推荐个人使用）
#              default（需要确认敏感操作）
PERMISSION_MODE=bypassPermissions

# （可选）Claude CLI 路径，留空则自动从 PATH 查找
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Codex bridge only:
# DEFAULT_MODEL=gpt-5.4
# SESSIONS_DIR=~/.lark-codex
# CODEX_HOME=~/.codex
# CODEX_CLI_PATH=/Applications/Codex.app/Contents/Resources/codex
